# DATABASE_URL=postgresql+asyncpg://user:pass@host:port/dbname

# App Settings
ENVIRONMENT=development
LOG_LEVEL=INFO
ADMIN_TELEGRAM_IDS=comma_separated_admin_telegram_ids

# Sentry (optional)
SENTRY_DSN=
