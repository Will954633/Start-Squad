# Telegram Bot Tokens
TELEGRAM_BOT_TOKEN=your_main_bot_token_here
PERSONA_MIA_TOKEN=your_mia_bot_token_here
PERSONA_DAMO_TOKEN=your_damo_bot_token_here
PERSONA_PRIYA_TOKEN=your_priya_bot_token_here
PERSONA_JAKE_TOKEN=your_jake_bot_token_here
PERSONA_LENA_TOKEN=your_lena_bot_token_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
